import json

#JSON 파일 쓰기
data = {
    'name': '서민걸',
    'age': 30,
    'city': '부산'
}

with open('example.json', 'w') as file:
    json.dump(data, file)

# JSON 파일 읽기
with open('example.json', 'r') as file:
    data = json.load(file)
    print(data)
