import PyPDF2
import pytesseract
from pdf2image import convert_from_path
from docx import Document
import re

class LegalDocumentProcessor:
    def __init__(self):
        self.min_text_length = 50  # Filter out noise
        
    def process_pdf(self, file_path):
        """Extract text from PDF, with OCR fallback for scanned documents"""
        text = ""
        
        # Try direct text extraction first
        with open(file_path, 'rb') as file:
            reader = PyPDF2.PdfReader(file)
            for page in reader.pages:
                text += page.extract_text()
        
        # If extraction yields minimal text, use OCR
        if len(text.strip()) < self.min_text_length:
            images = convert_from_path(file_path)
            text = ""
            for image in images:
                text += pytesseract.image_to_string(image)
        
        return self._clean_text(text)
    
    def process_docx(self, file_path):
        """Extract text from Word document, preserving structure"""
        doc = Document(file_path)
        text = []
        
        for paragraph in doc.paragraphs:
            if paragraph.text.strip():
                text.append(paragraph.text)
        
        return self._clean_text("\n".join(text))
    
    def _clean_text(self, text):
        """Remove excessive whitespace and normalize"""
        # Remove multiple spaces
        text = re.sub(r'\s+', ' ', text)
        # Remove page numbers and headers/footers (common patterns)
        text = re.sub(r'Page \d+ of \d+', '', text)
        return text.strip()



## 법적 맥락을 위한 지능형 청킹
import re
from typing import List, Dict

class LegalDocumentChunker:
    def __init__(self, max_chunk_size=1000, overlap=200):
        self.max_chunk_size = max_chunk_size
        self.overlap = overlap
        
        # Patterns for legal document structure
        self.section_pattern = re.compile(
            r'(?:^|\n)(?:Section|Article|Clause)\s+[\d\.]+',
            re.MULTILINE
        )
        self.subsection_pattern = re.compile(
            r'(?:^|\n)\([\da-z]+\)',
            re.MULTILINE
        )
    
    def chunk_document(self, text: str, metadata: Dict) -> List[Dict]:
        """Create semantically meaningful chunks with preserved context"""
        chunks = []
        
        # First, split by major sections
        sections = self._split_by_sections(text)
        
        for section_num, section_text in sections:
            # If section is small enough, keep it whole
            if len(section_text) <= self.max_chunk_size:
                chunks.append({
                    'text': section_text,
                    'metadata': {
                        **metadata,
                        'section': section_num,
                        'chunk_type': 'complete_section'
                    }
                })
            else:
                # Split large sections by subsections
                subsection_chunks = self._split_by_subsections(
                    section_text, 
                    section_num,
                    metadata
                )
                chunks.extend(subsection_chunks)
        
        return chunks
    
    def _split_by_sections(self, text: str) -> List[tuple]:
        """Split document by major sections"""
        matches = list(self.section_pattern.finditer(text))
        sections = []
        
        for i, match in enumerate(matches):
            start = match.start()
            end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
            section_num = match.group()
            section_text = text[start:end].strip()
            sections.append((section_num, section_text))
        
        # Handle text before first section
        if matches and matches[0].start() > 0:
            preamble = text[:matches[0].start()].strip()
            if preamble:
                sections.insert(0, ("Preamble", preamble))
        
        return sections if sections else [("Full Document", text)]
    
    def _split_by_subsections(self, text: str, section_num: str, 
                               metadata: Dict) -> List[Dict]:
        """Split large sections by subsections with overlap"""
        chunks = []
        matches = list(self.subsection_pattern.finditer(text))
        
        if not matches:
            # No subsections, use sliding window
            return self._sliding_window_split(text, section_num, metadata)
        
        for i, match in enumerate(matches):
            start = max(0, match.start() - self.overlap)
            end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
            
            chunk_text = text[start:end].strip()
            chunks.append({
                'text': chunk_text,
                'metadata': {
                    **metadata,
                    'section': section_num,
                    'subsection': match.group(),
                    'chunk_type': 'subsection'
                }
            })
        
        return chunks
    
    def _sliding_window_split(self, text: str, section_num: str,
                               metadata: Dict) -> List[Dict]:
        """Fallback: split by sentences with overlap"""
        chunks = []
        sentences = re.split(r'(?<=[.!?])\s+', text)
        
        current_chunk = ""
        for sentence in sentences:
            if len(current_chunk) + len(sentence) <= self.max_chunk_size:
                current_chunk += " " + sentence
            else:
                if current_chunk:
                    chunks.append({
                        'text': current_chunk.strip(),
                        'metadata': {
                            **metadata,
                            'section': section_num,
                            'chunk_type': 'sliding_window'
                        }
                    })
                current_chunk = sentence
        
        if current_chunk:
            chunks.append({
                'text': current_chunk.strip(),
                'metadata': {
                    **metadata,
                    'section': section_num,
                    'chunk_type': 'sliding_window'
                }
            })
        
        return chunks


##임베딩 및 벡터 저장

from qdrant_client import QdrantClient
from qdrant_client.models import Distance, VectorParams, PointStruct
from openai import OpenAI
import uuid

class LegalDocumentVectorStore:
    def __init__(self, collection_name="legal_documents"):
        self.client = QdrantClient(host="localhost", port=6333)
        self.collection_name = collection_name
        self.openai_client = OpenAI()
        self.embedding_dimension = 1536  # for text-embedding-ada-002
        
        # Create collection if it doesn't exist
        try:
            self.client.get_collection(collection_name)
        except:
            self.client.create_collection(
                collection_name=collection_name,
                vectors_config=VectorParams(
                    size=self.embedding_dimension,
                    distance=Distance.COSINE
                )
            )
    
    def embed_text(self, text: str) -> list:
        """Generate embedding using OpenAI"""
        response = self.openai_client.embeddings.create(
            input=text,
            model="text-embedding-ada-002"
        )
        return response.data[0].embedding
    
    def index_chunks(self, chunks: List[Dict]):
        """Index document chunks with their embeddings"""
        points = []
        
        for chunk in chunks:
            embedding = self.embed_text(chunk['text'])
            
            point = PointStruct(
                id=str(uuid.uuid4()),
                vector=embedding,
                payload={
                    'text': chunk['text'],
                    'metadata': chunk['metadata']
                }
            )
            points.append(point)
        
        # Batch upsert for efficiency
        self.client.upsert(
            collection_name=self.collection_name,
            points=points
        )
    
    def search(self, query: str, top_k: int = 5, 
               filter_conditions: Dict = None) -> List[Dict]:
        """Search for relevant chunks"""
        query_embedding = self.embed_text(query)
        
        search_params = {
            'collection_name': self.collection_name,
            'query_vector': query_embedding,
            'limit': top_k
        }
        
        # Add metadata filters if provided
        if filter_conditions:
            search_params['query_filter'] = filter_conditions
        
        results = self.client.search(**search_params)
        
        return [{
            'text': hit.payload['text'],
            'metadata': hit.payload['metadata'],
            'score': hit.score
        } for hit in results]

##쿼리 처리 및 LLM 통합
from openai import OpenAI
from typing import List, Dict

class LegalQueryProcessor:
    def __init__(self, vector_store: LegalDocumentVectorStore):
        self.vector_store = vector_store
        self.openai_client = OpenAI()
        
    def process_query(self, query: str, document_filter: Dict = None) -> Dict:
        """Process a legal query and return analysis with citations"""
        
        # Retrieve relevant chunks
        relevant_chunks = self.vector_store.search(
            query=query,
            top_k=5,
            filter_conditions=document_filter
        )
        
        if not relevant_chunks:
            return {
                'answer': 'No relevant information found in the document corpus.',
                'confidence': 'low',
                'citations': []
            }
        
        # Construct prompt with retrieved context
        prompt = self._build_prompt(query, relevant_chunks)
        
        # Get LLM response
        response = self.openai_client.chat.completions.create(
            model="gpt-4-turbo-preview",
            messages=[
                {
                    "role": "system",
                    "content": """You are a legal document analysis assistant. 
                    Analyze documents carefully and cite specific sections. 
                    If you cannot find definitive information, say so explicitly.
                    Never make assumptions about legal matters not stated in the provided text."""
                },
                {
                    "role": "user",
                    "content": prompt
                }
            ],
            temperature=0.1  # Low temperature for consistency
        )
        
        answer = response.choices[0].message.content
        
        # Post-process response
        return self._format_response(answer, relevant_chunks)
    
    def _build_prompt(self, query: str, chunks: List[Dict]) -> str:
        """Build a prompt with context and query"""
        context_parts = []
        
        for i, chunk in enumerate(chunks, 1):
            metadata = chunk['metadata']
            section_info = f"Section {metadata.get('section', 'Unknown')}"
            
            context_parts.append(
                f"[Source {i} - {section_info}]\n{chunk['text']}\n"
            )
        
        context = "\n".join(context_parts)
        
        prompt = f"""Based on the following excerpts from legal documents, answer this query:

Query: {query}

Document Excerpts:
{context}

Instructions:
1. Answer the query based solely on the provided excerpts
2. Cite specific sources using [Source N] notation
3. If the excerpts don't contain enough information, state this clearly
4. Identify any ambiguities or areas requiring human review
5. Format your response for legal professional review

Answer:"""
        
        return prompt
    
    def _format_response(self, answer: str, chunks: List[Dict]) -> Dict:
        """Format response with citations and metadata"""
        citations = []
        
        for i, chunk in enumerate(chunks, 1):
            if f"[Source {i}]" in answer or f"Source {i}" in answer:
                citations.append({
                    'source_number': i,
                    'text': chunk['text'][:200] + "...",  # Preview
                    'metadata': chunk['metadata'],
                    'relevance_score': chunk['score']
                })
        
        # Simple confidence heuristic based on citations and relevance
        confidence = 'high' if len(citations) >= 2 and chunks[0]['score'] > 0.8 else 'medium'
        if not citations:
            confidence = 'low'
        
        return {
            'answer': answer,
            'confidence': confidence,
            'citations': citations,
            'num_sources': len(chunks)
        }

## 다중 문서 분석 처리
class MultiDocumentAnalyzer:
    def __init__(self, query_processor: LegalQueryProcessor):
        self.query_processor = query_processor
    
    def compare_documents(self, query: str, 
                          document_ids: List[str]) -> Dict:
        """Compare specific clauses across multiple documents"""
        results_by_doc = {}
        
        for doc_id in document_ids:
            # Query each document separately
            result = self.query_processor.process_query(
                query=query,
                document_filter={'document_id': doc_id}
            )
            results_by_doc[doc_id] = result
        
        # Synthesize comparison
        comparison_prompt = self._build_comparison_prompt(
            query, 
            results_by_doc
        )
        
        # Get comparative analysis from LLM
        synthesis = self.query_processor.openai_client.chat.completions.create(
            model="gpt-4-turbo-preview",
            messages=[
                {
                    "role": "system",
                    "content": """You are analyzing differences between legal documents.
                    Identify conflicts, inconsistencies, and areas requiring attention.
                    Be specific about which documents contain which provisions."""
                },
                {
                    "role": "user",
                    "content": comparison_prompt
                }
            ],
            temperature=0.1
        )
        
        return {
            'comparative_analysis': synthesis.choices[0].message.content,
            'individual_results': results_by_doc
        }
    
    def _build_comparison_prompt(self, query: str, 
                                   results_by_doc: Dict) -> str:
        """Build prompt for cross-document comparison"""
        doc_summaries = []
        
        for doc_id, result in results_by_doc.items():
            doc_summaries.append(
                f"Document {doc_id}:\n{result['answer']}\n"
            )
        
        return f"""Compare how these documents address: {query}

{chr(10).join(doc_summaries)}

Provide a comparative analysis highlighting:
1. Key differences
2. Potential conflicts
3. Missing provisions in any document
4. Recommendations for human review"""

